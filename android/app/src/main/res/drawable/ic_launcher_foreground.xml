    android:viewportHeight="108"> <!-- 视口高度 / Viewport height -->
    <!-- 下载箭头图标 / Download arrow icon -->
    <path <!-- 路径 / Path -->
        android:fillColor="#FFFFFF" <!-- 白色填充 / White fill -->
