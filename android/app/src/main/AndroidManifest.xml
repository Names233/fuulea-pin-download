<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限 / Internet permission -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 相机权限(扫码需要) / Camera permission (required for QR scanning) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- 前台服务权限 / Foreground service permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- 声明需要相机硬件 / Declare camera hardware requirement -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FuuleaDownloader"
        tools:targetApi="35">

        <!-- 主 Activity / Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FuuleaDownloader">

            <!-- 启动器 Intent / Launcher Intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
